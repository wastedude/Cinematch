# ── TMDB API (server-side only — never expose this to the browser) ──────────
# Get your free v3 API key at: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_v3_api_key_here

# ── Supabase (safe to expose — RLS handles access control) ──────────────────
# Find these in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── App URL ──────────────────────────────────────────────────────────────────
# Local development:
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# Production (change to your Vercel / custom domain):
# NEXT_PUBLIC_BASE_URL=https://your-app.vercel.app
